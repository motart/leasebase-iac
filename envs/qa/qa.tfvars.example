# Leasebase QA Environment - Terraform Variables
# Copy this file to qa.tfvars and fill in the values.
# NEVER commit qa.tfvars with real secrets to version control.

############################
# AWS
############################
aws_region = "us-east-1"
vpc_cidr   = "10.20.0.0/16"

############################
# Database
############################
db_name                = "leasebase_qa"
db_username            = "leasebase"
db_password            = "CHANGE_ME_secure_password_here"
db_engine_version      = "16.0"
db_instance_class      = "db.t3.small"
db_allocated_storage   = 50
db_deletion_protection = true

############################
# API / ECS
############################
api_port             = 4000
api_healthcheck_path = "/healthz"
# Use ECR URL after first apply
api_container_image  = "leasebase-qa-api:latest"
ecs_task_cpu         = "512"
ecs_task_memory      = "1024"
ecs_desired_count    = 2

############################
# Cognito
############################
cognito_domain_suffix = "qa-123456789012"

cognito_callback_urls = [
  "https://qa.leasebase.io/auth/callback"
]
cognito_logout_urls = [
  "https://qa.leasebase.io/login"
]
cognito_advanced_security_mode = "AUDIT"

############################
# Document Storage
############################
documents_bucket_suffix = "qa-123456789012"
documents_cors_origins = [
  "https://qa.leasebase.io"
]

############################
# Stripe
############################
# Use test mode keys for QA
stripe_secret_key      = "sk_test_CHANGE_ME"
stripe_publishable_key = "pk_test_CHANGE_ME"
stripe_webhook_secret  = "whsec_CHANGE_ME"

############################
# Application Secrets
############################
jwt_secret     = "CHANGE_ME_generate_secure_random_string"
session_secret = "CHANGE_ME_generate_secure_random_string"

############################
# Email (SES)
############################
ses_from_email = "noreply@leasebase.io"

############################
# Web Frontend (ECS)
############################
web_container_image = "leasebase-qa-web:latest"
web_port            = 3000
web_task_cpu        = "256"
web_task_memory     = "512"
web_desired_count   = 2

web_api_base_url = "https://api.qa.leasebase.io"

############################
# Application URLs
############################
api_base_url = "https://api.qa.leasebase.io"
web_base_url = "https://qa.leasebase.io"

############################
# Logging
############################
log_retention_days = 30
